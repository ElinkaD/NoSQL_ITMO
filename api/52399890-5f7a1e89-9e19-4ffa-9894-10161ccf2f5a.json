        "description": "GET /health с живой cookie должен вернуть ту же cookie, но не создавать новую сессию."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Body is exactly {status: ok}', function () {",
              "  pm.expect(pm.response.json()).to.eql({ status: 'ok' });",
              "});",
              "",
              "const setCookie = pm.response.headers.get('Set-Cookie');",
              "const pattern = new RegExp('^X-Session-Id=([0-9a-f]{32}); HttpOnly; Path=/; Max-Age=' + pm.collectionVariables.get('session_ttl') + '$');",
              "const match = setCookie && setCookie.match(pattern);",
              "",
              "pm.test('Health returns the same sid', function () {",
              "  pm.expect(match && match[1]).to.eql(pm.collectionVariables.get('session_id'));",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Create Session from Invalid Cookie",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Cookie",
            "value": "X-Session-Id=bad"
          }
        ],
        "url": {
          "raw": "http://{{host}}:{{port}}/session",
          "protocol": "http",
          "host": [
            "{{host}}"
          ],
          "port": "{{port}}",
          "path": [
            "session"
          ]
        },
        "description": "POST /session с невалидной cookie должен создать новую сессию и вернуть 201."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Response body is empty', function () {",
              "  pm.expect(pm.response.text()).to.eql('');",
              "});",
              "",
              "const setCookie = pm.response.headers.get('Set-Cookie');",
              "const pattern = /^X-Session-Id=([0-9a-f]{32}); HttpOnly; Path=\\/; Max-Age=\\d+$/;",
              "const match = setCookie && setCookie.match(pattern);",
              "",
              "pm.test('New valid sid is returned', function () {",
              "  pm.expect(match).to.not.be.null;",
              "});",
              "",
              "pm.test('Returned sid is not the invalid one', function () {",
              "  pm.expect(match && match[1]).to.not.eql('bad');",
              "});"
            ]
          }
        }
      ]
    },
