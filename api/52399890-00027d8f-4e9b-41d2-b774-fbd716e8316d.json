		{
			"name": "Recreate Session after TTL Expiration",
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"pm.test('Status is 201', function () {",
							"  pm.response.to.have.status(201);",
							"});",
							"",
							"pm.test('Response body is empty', function () {",
							"  pm.expect(pm.response.text()).to.eql('');",
							"});",
							"",
							"const setCookie = pm.response.headers.get('Set-Cookie');",
							"const pattern = /^X-Session-Id=([0-9a-f]{32}); HttpOnly; Path=\\/; Max-Age=\\d+$/;",
							"const match = setCookie && setCookie.match(pattern);",
							"",
							"pm.test('A new sid is returned', function () {",
							"  pm.expect(match).to.not.be.null;",
							"  pm.expect(match[1]).to.not.eql(pm.collectionVariables.get('expired_session_id'));",
							"});",
							"",
							"if (match) {",
							"  pm.collectionVariables.set('session_id', match[1]);",
							"  pm.collectionVariables.set('expired_session_id', match[1]);",
							"}"
						],
						"id": "b4876dbb-ad36-4076-b8d1-18f9807e6172"
