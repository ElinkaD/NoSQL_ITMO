	"item": [
		{
			"name": "Health without Cookie",
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"pm.test('Status is 200', function () {",
							"  pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test('Body is exactly {status: ok}', function () {",
							"  pm.expect(pm.response.json()).to.eql({ status: 'ok' });",
							"});",
							"",
							"pm.test('Set-Cookie is absent', function () {",
							"  pm.expect(pm.response.headers.has('Set-Cookie')).to.eql(false);",
							"});"
						],
						"id": "786e3a4b-b0cc-4b08-aa19-5fbbea8b3ce9"
					}
				}
			],
			"id": "52399890-c439ab85-1a20-4c41-9a13-279b2b9e29d6",
